-        game_id: gameId,
-        predicted_winner_team_id: predictedTeamId,
-      },
-      { onConflict: "user_id, game_id" }
-    )
-    .select()
-    .single();
-
-  if (error) {
-    console.error("Error submitting prediction:", error);
-    throw new Error("Failed to save prediction.");
-  }
