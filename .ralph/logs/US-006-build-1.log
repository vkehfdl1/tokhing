+    if (estimatedCost >= amount) {
+      break;
+    }
+
+    high *= 2;
+  }
+
+  for (let i = 0; i < 80; i += 1) {
+    const mid = (low + high) / 2;
+    const estimatedCost = calculateBuyCost(qValues, b, outcome, mid);
+
+    if (estimatedCost <= amount) {
+      low = mid;
+    } else {
+      high = mid;
+    }
+  }
+
+  return truncateToEightDigits(low);
+};
