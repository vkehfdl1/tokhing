+
+  if (error) {
+    console.error("Error calling execute_buy_order RPC:", error);
+    throw new Error("매수 주문 처리 중 오류가 발생했습니다");
+  }
+
+  return parseOrderResult(data as OrderRpcResponse | null, "BUY");
+};
