+});
+
+const formatGameTime = (gameTime: string | null): string => {
+  if (!gameTime) {
+    return "--:--";
+  }
+
+  const [hour = "", minute = ""] = gameTime.split(":");
+  if (!hour || !minute) {
+    return gameTime;
