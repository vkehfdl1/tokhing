+  const shiftedHome = Math.exp((qValues.HOME - maxQ) / b);
+  const shiftedAway = Math.exp((qValues.AWAY - maxQ) / b);
+  const shiftedDraw = Math.exp((qValues.DRAW - maxQ) / b);
+
+  return maxQ + b * Math.log(shiftedHome + shiftedAway + shiftedDraw);
