+            {loading ? "조회 중..." : "마켓 새로고침"}
+          </Button>
+        </div>
+      </Card>
+
+      {loading ? (
+        <Card className={isMobile ? "p-4" : "p-6"}>
+          <p className="text-sm text-muted-foreground">마켓 목록을 불러오는 중...</p>
+        </Card>
