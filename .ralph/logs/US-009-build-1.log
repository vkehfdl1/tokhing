+        text: `유동성 b값이 ${result.previousB} → ${result.currentB} 로 변경되었습니다. 이후 생성되는 마켓부터 적용됩니다.`,
+      });
+    } catch (error) {
+      setMessage({
+        type: "error",
+        text:
+          error instanceof Error
+            ? error.message
+            : "b값 저장 중 오류가 발생했습니다.",
+      });
