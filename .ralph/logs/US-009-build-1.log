+      setMessage({
+        type: "error",
+        text:
+          error instanceof Error
+            ? error.message
+            : "마켓 종료 중 오류가 발생했습니다.",
+      });
+    } finally {
+      setActiveMarketId(null);
+    }
+  };
+
+  const runCancel = async (market: MarketListItem) => {
+    const confirmed = window.confirm(
