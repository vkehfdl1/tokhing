+  if (!Number.isFinite(previousB) || !Number.isFinite(currentB) || currentB <= 0) {
+    throw new Error("b값 변경 응답 형식이 올바르지 않습니다");
+  }
+
+  return {
+    previousB,
+    currentB,
+  };
+};
