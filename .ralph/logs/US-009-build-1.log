+            : "마켓 정산 중 오류가 발생했습니다.",
+      });
+    } finally {
+      setActiveMarketId(null);
+    }
+  };
+
+  const runClose = async (market: MarketListItem) => {
+    setMessage(null);
+    setActiveMarketId(market.id);
+    try {
+      await closeMarket(market.id);
+      setMessage({
+        type: "success",
