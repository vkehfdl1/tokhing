+export const updateLiquidityB = async (
+  nextB: number
+): Promise<LiquiditySettingResult> => {
+  if (!Number.isFinite(nextB) || nextB <= 0) {
+    throw new Error("b값은 0보다 큰 숫자여야 합니다");
