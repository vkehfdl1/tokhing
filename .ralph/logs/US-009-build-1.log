+  const [message, setMessage] = useState<{
+    type: "success" | "error";
+    text: string;
+  } | null>(null);
+
+  const fetchLiquidityB = async () => {
+    try {
+      setLoading(true);
+      const currentValue = await getLiquidityB();
+      setCurrentB(currentValue);
+      setNextB(String(currentValue));
+    } catch (error) {
