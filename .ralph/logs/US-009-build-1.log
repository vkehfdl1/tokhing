+                value={nextB}
+                onChange={(event) => setNextB(event.target.value)}
+                disabled={saving}
+                className="text-black"
+              />
+            </div>
+            <Button type="submit" disabled={saving} className="h-12 rounded-lg">
+              {saving ? "저장 중..." : "b값 저장"}
+            </Button>
+          </form>
+        )}
+      </Card>
+    </div>
+  );
+}
