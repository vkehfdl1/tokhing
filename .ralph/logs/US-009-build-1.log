+        </p>
+      </div>
+
+      {message ? (
+        <div
+          className={`rounded-lg p-3 text-sm ${
+            message.type === "success"
+              ? "bg-green-50 text-green-700"
+              : "bg-red-50 text-red-600"
+          }`}
+        >
+          {message.text}
+        </div>
+      ) : null}
+
+      <Card className={isMobile ? "p-4" : "p-6"}>
+        {loading ? (
+          <p className="text-sm text-muted-foreground">현재 b값을 불러오는 중...</p>
