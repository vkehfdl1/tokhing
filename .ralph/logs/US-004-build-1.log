+                  <option key={user.id} value={user.id}>
+                    {String(user.student_number)} - {user.username}
+                  </option>
+                ))
+              )}
+            </Select>
+          </div>
+
+          <div>
+            <Label htmlFor="single-amount" className="block mb-2">
+              지급 금액
+            </Label>
+            <Input
+              id="single-amount"
+              type="number"
+              min="1"
+              value={singleAmount}
+              onChange={(event) => setSingleAmount(event.target.value)}
