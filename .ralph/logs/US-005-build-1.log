                ) : (
                  // Desktop Layout (unchanged)
                  <div className="grid grid-cols-3 items-center text-center text-gray-800">
                    {/* Home Team */}
                    <div className="flex flex-col">
                      <span className="font-bold text-2xl">
                        {game.home_team.name}
                      </span>
                      <span className="text-sm text-gray-500">
