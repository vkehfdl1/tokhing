+}
+
+type TeamRelation = TeamWithShortName | TeamWithShortName[] | null;
+
+interface GameForMarketListRow {
+  id: number;
+  game_date: string;
+  game_time: string | null;
+  game_status: string;
+  home_team: TeamRelation;
+  away_team: TeamRelation;
+}
