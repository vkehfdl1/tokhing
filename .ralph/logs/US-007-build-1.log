              }`}
            >
              {tab.label}
            </button>
          ))}
        </div>
      </div>

      {activeTab === "ORDERS" && (
        <div className="mb-5 mt-1 flex flex-col items-center">
          <div className="relative mb-1 flex items-center justify-center gap-1">
