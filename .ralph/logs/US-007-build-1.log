+      homeTeamShortName: homeTeam.short_name ?? null,
+      awayTeamShortName: awayTeam.short_name ?? null,
+    });
+  });
+
+  return items.sort(
+    (a, b) => new Date(b.updatedAt).getTime() - new Date(a.updatedAt).getTime()
+  );
