+      marketsById: new Map<number, MarketForHistoryContextRow>(),
+      gamesById: new Map<number, GameForHistoryContextRow>(),
+    };
+  }
+
+  const marketsById = new Map<number, MarketForHistoryContextRow>(
+    markets.map((market) => [market.id, market])
+  );
