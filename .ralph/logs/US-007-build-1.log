+  if (Number.isNaN(startAt.getTime())) {
+    throw new Error("조회 날짜 형식이 올바르지 않습니다");
+  }
+
+  const endAt = new Date(startAt.getTime() + 24 * 60 * 60 * 1000);
+  return {
+    startAtIso: startAt.toISOString(),
+    endAtIso: endAt.toISOString(),
+  };
+};
