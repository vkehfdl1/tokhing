  q_home NUMERIC,
  q_away NUMERIC,
  q_draw NUMERIC,
  b NUMERIC
)
RETURNS NUMERIC
LANGUAGE plpgsql
IMMUTABLE
AS $$
DECLARE
  v_max_q NUMERIC;
BEGIN
  IF q_home IS NULL OR q_away IS NULL OR q_draw IS NULL THEN
    RAISE EXCEPTION 'q 값은 NULL일 수 없습니다';
  END IF;
