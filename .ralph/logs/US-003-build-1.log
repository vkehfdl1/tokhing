+GRANT EXECUTE ON FUNCTION public.lmsr_prices(INTEGER) TO anon, authenticated;
+GRANT EXECUTE ON FUNCTION public.execute_buy_order(UUID, INTEGER, TEXT, NUMERIC) TO anon, authenticated;
